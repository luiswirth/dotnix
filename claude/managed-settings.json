    "deny": [
      "Bash(sudo *)",
      "Bash(doas *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/id_ed25519)",
      "Read(**/id_rsa)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.claude/.credentials.json)"
    ]
  }
}
